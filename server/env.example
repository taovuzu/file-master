# Database
MONGODB_URI=mongodb://localhost:27017
DB_NAME=filemaster

# JWT Secrets
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=7d
USER_TEMPORARY_TOKEN_EXPIRY=900000

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Frontend URLs
FRONTEND_URL=http://localhost:5173
CLIENT_SSO_REDIRECT_URL=http://localhost:5173

# Session Secret
EXPRESS_SESSION_SECRET=your_session_secret_here
COOKIE_SECRET=your_cookie_secret_here

# CORS
CORS_ORIGIN=http://localhost:5173

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
RAZORPAY_PRO_PLAN_ID=your_pro_plan_id_here
RAZORPAY_BUSINESS_PLAN_ID=your_business_plan_id_here

# Redis Configuration
REDIS_URL=redis://localhost:6379

# File Upload Limits
MAX_FILE_SIZE=104857600
MAX_FILES=10